# Local-only defaults for infra/docker-compose.yml. Copy to infra/.env.
# NEVER put real secrets here — production secrets go through the secrets manager (SEC-06).

POSTGRES_USER=unheard
POSTGRES_PASSWORD=unheard
POSTGRES_DB=unheard

MINIO_ROOT_USER=unheard
MINIO_ROOT_PASSWORD=unheard-local

# Gateway
PORT=8080
DATABASE_URL=postgres://unheard:unheard@localhost:5432/unheard
REDIS_URL=redis://localhost:6379
OBJECT_STORE_ENDPOINT=http://localhost:9000
MASKING_SERVICE_URL=http://localhost:8081
